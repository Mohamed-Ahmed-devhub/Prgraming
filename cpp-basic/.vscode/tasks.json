
    {
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: Build to Output Folder",
            "command": "powershell",
            "args": [
                "-Command",
                "if (!(Test-Path '${fileDirname}\\output')) { New-Item -ItemType Directory -Path '${fileDirname}\\output' }; & C:\\MinGW\\bin\\g++.exe -g '${file}' -o '${fileDirname}\\output\\${fileBasenameNoExtension}.exe'"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}